rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwnerExisting() {
      return request.auth.uid == resource.data.userId;
    }

    function isOwnerNew() {
      return request.auth.uid == request.resource.data.userId;
    }

    // Generic rule for all user-owned collections
    match /{collection}/{docId} {

      // Apply only to my known collections
      allow create: if isAuthenticated()
                    && isOwnerNew()
                    && isAllowedCollection(collection);

      allow read, update, delete: if isAuthenticated()
                                  && isOwnerExisting()
                                  && isAllowedCollection(collection);
    }
    
    // Special case: users collection, which do not hold the userId property
    match /users/{userId} {

      allow create: if isAuthenticated()
                    && request.auth.uid == userId;

      allow read, update, delete: if isAuthenticated()
                                  && request.auth.uid == userId;
    }

    
    function isAllowedCollection(collection) {
      return collection in [
        'recipes',
        'meals',
        'meal-categories',
        'members',
        'ingredients',
        'ingredient-categories',
        'cuisines',
        'recipe-categories',
      ];
    }
  }
}